# Required for real Cognee memory + Claude-synthesized clinical answers.
# Get one at https://console.anthropic.com/
LLM_API_KEY=

# Optional: point Setu Swasth at a remote Cognee Cloud / self-hosted
# instance instead of running Cognee embedded in this process.
# COGNEE_BASE_URL=
# COGNEE_API_KEY=

PORT=8000

# --------------------------------------------------------------------------
# Real-time OTP delivery over email — 100% free, no SMS-gateway bill.
# Leave all of these blank and the app automatically falls back to
# on-screen "demo OTP" mode, so it still runs end-to-end without any of
# this configured.
#
# EASIEST FREE OPTION — Gmail App Password (500 emails/day, free forever):
#   1. Turn on 2-Step Verification: myaccount.google.com/security
#   2. Create an App Password: myaccount.google.com/apppasswords
#   3. SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
#      SMTP_PASS=<the 16-character app password, not your real password>
#
# ALTERNATIVE — Brevo / Resend free transactional-email tier (~300/day,
# no credit card, better deliverability for a real deployment):
#   SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   SMTP_USER=<brevo login>  SMTP_PASS=<brevo SMTP key>
# --------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Secret used to HMAC-hash OTPs in memory (never stored in plaintext).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
OTP_SECRET=
